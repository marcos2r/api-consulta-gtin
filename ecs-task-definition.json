{
  "family": "api-consulta-gtin-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::107174605256:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "api-consulta-gtin-container",
      "image": "107174605256.dkr.ecr.us-east-1.amazonaws.com/pairus/api-consulta-gtin:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "AMBIENTE",
          "value": "producao"
        },
        {
          "name": "REDIS_URL",
          "value": "redis://127.0.0.1:6379/0"
        },
        {
          "name": "CERTIFICADO_CAMINHO",
          "value": "cert.pfx"
        },
        {
          "name": "CERTIFICADO_SENHA",
          "value": "importcar4x4"
        },
        {
          "name": "EANDATA_API_KEY",
          "value": "7532F77C687B9EBE"
        },
        {
          "name": "COSMOS_API_TOKEN",
          "value": "DwC2AVrJG-w7ZxcNEgb16A"
        },
        {
          "name": "CONTATO_NOME",
          "value": "MARCOS RICARDO RODRIGUES"
        },
        {
          "name": "EMPRESA_NOME",
          "value": "PAIRUS Soluções Tecnológicas"
        }
      ],
      "dependsOn": [
        {
          "containerName": "redis-cache",
          "condition": "START"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/api-consulta-gtin",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "ecs"
        }
      }
    },
    {
      "name": "redis-cache",
      "image": "redis:alpine",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 6379,
          "protocol": "tcp"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/api-consulta-gtin",
          "awslogs-region": "us-east-1",
          "awslogs-stream-prefix": "redis"
        }
      }
    }
  ]
}